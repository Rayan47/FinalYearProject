ows\")\nprint(f\"Damage ratio in Validation: {y_val.mean():.2%}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:41.786858Z","iopub.execute_input":"2026-04-08T22:15:41.787074Z","iopub.status.idle":"2026-04-08T22:15:45.577003Z","shell.execute_reply.started":"2026-04-08T22:15:41.787055Z","shell.execute_reply":"2026-04-08T22:15:45.576238Z"}},"outputs":[{"name":"stdout","text":"Training set: 5515664 windows\nValidation set: 1378916 windows\nDamage ratio in Validation: 38.67%\n","output_type":"stream"}],"execution_count":4},{"cell_type":"code","source":"\nclass DamageDetectionModel(nn.Module):\n    def __init__(self, num_features=20, window_size=5):\n        super(DamageDetectionModel, self).__init__()\n        \n        # Feature extraction using deeper, narrower convolutions\n        self.features = nn.Sequential(\n            nn.Conv1d(num_features, 64, kernel_size=5, stride=1, padding=2),\n            nn.BatchNorm1d(64),\n            nn.ReLU(),\n            nn.MaxPool1d(2),\n            \n            nn.Conv1d(64, 128, kernel_size=3, padding=1),\n            nn.BatchNorm1d(128),\n            nn.ReLU(),\n            nn.MaxPool1d(2),\n            \n            nn.Conv1d(128, 256, kernel_size=3, padding=1),\n            nn.BatchNorm1d(256),\n            nn.ReLU(),\n            nn.AdaptiveAvgPool1d(1) # Collapses time dimension to 1\n        )\n        \n        self.classifier = nn.Sequential(\n            nn.Linear(256, 128),\n            nn.ReLU(),\n            nn.Dropout(0.5), # High dropout to force generalization\n            nn.Linear(128, 1) # Logit output\n        )\n\n    def forward(self, x):\n        # Input shape: (Batch, Features, Time)\n        x = self.features(x)\n        x = x.view(x.size(0), -1)\n        return self.classifier(x)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:45.577914Z","iopub.execute_input":"2026-04-08T22:15:45.578175Z","iopub.status.idle":"2026-04-08T22:15:45.585287Z","shell.execute_reply.started":"2026-04-08T22:15:45.578153Z","shell.execute_reply":"2026-04-08T22:15:45.58429Z"}},"outputs":[],"execution_count":5},{"cell_type":"code","source":"\nclass UAVDataset(Dataset):\n    def __init__(self, X, y):\n        # Convert NumPy to Tensors once to save time during the loop\n        # We use float32 for features and float32 for binary labels (required for BCEWithLogitsLoss)\n        self.X = torch.from_numpy(X).float()\n        self.y = torch.from_numpy(y).float()\n\n    def __len__(self):\n        return len(self.y)\n\n    def __getitem__(self, idx):\n        return self.X[idx], self.y[idx]","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:45.586393Z","iopub.execute_input":"2026-04-08T22:15:45.586624Z","iopub.status.idle":"2026-04-08T22:15:45.605257Z","shell.execute_reply.started":"2026-04-08T22:15:45.586604Z","shell.execute_reply":"2026-04-08T22:15:45.604475Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"# Assuming X_train, y_train are your windowed numpy arrays\ntrain_dataset = UAVDataset(X_train, y_train)\nval_dataset = UAVDataset(X_val, y_val)\n\ntrain_loader = DataLoader(\n    train_dataset, \n    batch_size=4096, \n    shuffle=True, \n    num_workers=4,        # Parallel data loading\n    pin_memory=True,      # Faster transfer to T4 GPUs\n    drop_last=True,\n    prefetch_factor=4\n)\n\nval_loader = DataLoader(\n    val_dataset, \n    batch_size=4096, \n    shuffle=False, \n    num_workers=4, \n    pin_memory=True,\n    prefetch_factor=4\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:45.605999Z","iopub.execute_input":"2026-04-08T22:15:45.606231Z","iopub.status.idle":"2026-04-08T22:15:45.662798Z","shell.execute_reply.started":"2026-04-08T22:15:45.60621Z","shell.execute_reply":"2026-04-08T22:15:45.662129Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"\n# 1. Hyperparameters & Setup\nnum_epochs = 50\nbest_val_loss = float('inf')\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nmodel = DamageDetectionModel().to(device)\n\n# Wrap for Dual T4 GPUs\nif torch.cuda.device_count() > 1:\n    print(f\"Using {torch.cuda.device_count()} GPUs!\")\n    model = nn.DataParallel(model)\n# Initialize Optimizer and Scheduler\noptimizer = optim.Adam(model.parameters(), lr=1e-3, weight_decay=1e-4)\ncriterion = nn.BCEWithLogitsLoss()\nscaler = GradScaler() # For Mixed Precision (T4 optimized)\n\n# Learning Rate Scheduler: Reduces LR if validation loss doesn't improve for 3 epochs\nscheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=3)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:45.663854Z","iopub.execute_input":"2026-04-08T22:15:45.664304Z","iopub.status.idle":"2026-04-08T22:15:49.266468Z","shell.execute_reply.started":"2026-04-08T22:15:45.664229Z","shell.execute_reply":"2026-04-08T22:15:49.265846Z"}},"outputs":[{"name":"stdout","text":"Using 2 GPUs!\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"def validate_with_metrics(model, loader, criterion, device):\n    model.eval()\n    val_loss = 0\n    all_preds = []\n    all_labels = []\n    \n    with torch.no_grad():\n        for inputs, labels in loader:\n            inputs = inputs.to(device, non_blocking=True).transpose(1, 2)\n            labels = labels.to(device, non_blocking=True).unsqueeze(1)\n            \n            with autocast(device_type='cuda'):\n                outputs = model(inputs)\n                loss = criterion(outputs, labels)\n            \n            val_loss += loss.item()\n            \n            # Convert logits to binary predictions\n            preds = (torch.sigmoid(outputs) > 0.5).float()\n            \n            all_preds.extend(preds.cpu().numpy())\n            all_labels.extend(labels.cpu().numpy())\n            \n    # Calculate Metrics\n    avg_loss = val_loss / len(loader)\n    precision = precision_score(all_labels, all_preds, zero_division=0)\n    recall = recall_score(all_labels, all_preds, zero_division=0)\n    f1 = f1_score(all_labels, all_preds, zero_division=0)\n    cm = confusion_matrix(all_labels, all_preds)\n    \n    return avg_loss, precision, recall, f1, cm","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:49.267592Z","iopub.execute_input":"2026-04-08T22:15:49.268037Z","iopub.status.idle":"2026-04-08T22:15:49.274573Z","shell.execute_reply.started":"2026-04-08T22:15:49.268011Z","shell.execute_reply":"2026-04-08T22:15:49.273628Z"}},"outputs":[],"execution_count":9},{"cell_type":"code","source":"# 3. Main Training Loop\nprint(f\"Starting Training on {device}...\")\n\nfor epoch in range(num_epochs):\n    # --- Training Phase ---\n    model.train()\n    train_loss = 0\n    \n    # Use tqdm for a nice progress bar in Kaggle\n    pbar = tqdm(train_loader, desc=f\"Epoch {epoch+1}/{num_epochs} [Train]\")\n    for inputs, labels in pbar:\n        inputs = inputs.to(device, non_blocking=True).transpose(1, 2)\n        labels = labels.to(device, non_blocking=True).unsqueeze(1)\n\n        optimizer.zero_grad()\n\n        with autocast(device_type='cuda'):\n            outputs = model(inputs)\n            loss = criterion(outputs, labels)\n\n        scaler.scale(loss).backward()\n        scaler.step(optimizer)\n        scaler.update()\n\n        train_loss += loss.item()\n        pbar.set_postfix({'loss': f\"{loss.item():.4f}\"})\n\n    avg_train_loss = train_loss / len(train_loader)\n\n    if (epoch+1) % 5 == 0:\n        avg_val_loss, val_prec, val_rec, val_f1, val_cm = validate_with_metrics(model, val_loader, criterion, device)\n        \n        scheduler.step(avg_val_loss)\n        current_lr = optimizer.param_groups[0]['lr']\n        print(f\"\\n📊 Epoch {epoch+1} Metrics:\")\n        print(f\"Val Loss: {avg_val_loss:.4f} | F1-Score: {val_f1:.4f}\")\n        print(f\"Precision: {val_prec:.4f} (Avoids false alarms)\")\n        print(f\"Recall: {val_rec:.4f} (Actually catches damage)\")\n        print(f\"Confusion Matrix:\\n{val_cm}\")\n        print(f\"\\nSummary - Epoch {epoch+1}:\")\n        print(f\"Train Loss: {avg_train_loss:.4f} | Val Loss: {avg_val_loss:.4f} | LR: {current_lr}\")\n    \n        # --- Checkpointing ---\n        if avg_val_loss < best_val_loss:\n            best_val_loss = avg_val_loss\n            # Save the underlying model if using DataParallel\n            save_obj = model.module.state_dict() if isinstance(model, nn.DataParallel) else model.state_dict()\n            torch.save(save_obj, 'best_uav_model.pth')\n            print(\"🚀 New best model saved!\")\n        \n    print(\"-\" * 30)\n\nprint(\"Training Complete!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-08T22:15:49.276903Z","iopub.execute_input":"2026-04-08T22:15:49.277185Z","execution_failed":"2026-04-08T22:16:35.041Z"}},"outputs":[{"name":"stdout","text":"Starting Training on cuda...\n","output_type":"stream"},{"name":"stderr","text":"Epoch 1/50 [Train]:  88%|████████▊ | 1179/1346 [00:45<00:05, 29.88it/s, loss=0.3055]","output_type":"stream"}],"execution_count":null},{"cell_type":"code","source":"import seaborn as sns\nimport matplotlib.pyplot as plt\n\nplt.figure(figsize=(6,5))\nsns.heatmap(val_cm, annot=True, fmt='d', cmap='Blues', xticklabels=['Healthy', 'Damaged'], yticklabels=['Healthy', 'Damaged'])\nplt.xlabel('Predicted')\nplt.ylabel('Actual')\nplt.title('Final Validation Confusion Matrix')\nplt.show()","metadata":{"trusted":true,"execution":{"execution_failed":"2026-04-08T22:16:35.041Z"}},"outputs":[],"execution_count":null}]}